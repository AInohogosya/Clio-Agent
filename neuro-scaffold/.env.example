# Neuro-Scaffold Environment Configuration

# Security
NEURO_CLIO_API_KEY=your-api-key-here
NEURO_JWT_SECRET=your-jwt-secret-here

# Gateway
NEURO_GATEWAY_HOST=0.0.0.0
NEURO_GATEWAY_PORT=9090

# Agent
NEURO_MAX_ITERATIONS=50
NEURO_SHELL_TIMEOUT_SECONDS=120

# LLM
NEURO_LLM_PROVIDER=openai
NEURO_LLM_MODEL=gpt-4o
NEURO_LLM_API_KEY=your-llm-api-key

# Logging
NEURO_LOG_LEVEL=INFO
